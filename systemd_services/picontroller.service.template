[Unit]
Description=Run Picontroller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=bash -c "${PICONTROLLER_PROJECT_PATH}/scripts/picontroller ${PICONTROLLER_CONFIGURATION_PATH}"
WorkingDirectory=${PICONTROLLER_PROJECT_PATH}
User=${PICONTROLLER_HUB_USER}
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

